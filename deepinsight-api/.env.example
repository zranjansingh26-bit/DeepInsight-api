# ──────────────────────────────────────────────
# DeepInsight Starter Suite — Environment Config
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret
SUPABASE_STORAGE_BUCKET=DeepInsights

# LLM Provider Selection (Claude | OpenAI | Gemini)
LLM_PROVIDER=Claude

# LLM API Keys (at least one required for chat)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Email
RESEND_API_KEY=
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Application
APP_ENV=development
APP_NAME=DeepInsight Starter Suite
APP_VERSION=1.0.0
LOG_LEVEL=INFO
CORS_ORIGINS=*

# Server
HOST=0.0.0.0
PORT=8000

# Limits
MAX_UPLOAD_SIZE_MB=50